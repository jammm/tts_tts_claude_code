# Auto-generated by install_windows.ps1. Do not edit the installed copy.
# Starts the ROCm Kokoro TTS server with torch.compile + Triton on gfx1201.
# Sources vcvars64 first so Triton-Windows can find the Windows SDK headers
# it needs to build compiled kernels.

$VenvPython = "__VENV_PYTHON__"
$DaemonDir  = "__DAEMON_DIR__"
$RocmBin    = "__ROCM_BIN__"
$VsVcVars   = "C:\Program Files\Microsoft Visual Studio\2022\Community\VC\Auxiliary\Build\vcvars64.bat"

$LogDir = Join-Path $env:LOCALAPPDATA "voice-plugin\logs"
if (-not (Test-Path $LogDir)) { New-Item -ItemType Directory -Path $LogDir -Force | Out-Null }
$ts = (Get-Date).ToString("yyyyMMdd-HHmmss")
$logFile = Join-Path $LogDir "kokoro-$ts.log"

$TritonCache = Join-Path $env:LOCALAPPDATA "voice-plugin\triton-cache"
if (-not (Test-Path $TritonCache)) { New-Item -ItemType Directory -Path $TritonCache -Force | Out-Null }

# Env vars set here propagate to cmd.exe's child python. Avoid setting PATH
# inside cmd AFTER vcvars — %PATH% expands at parse time (before vcvars
# modifies it) so `set PATH=X;%PATH%` would clobber MSVC. Easier to prepend
# RocmBin here and let vcvars append MSVC inside cmd.
$env:PATH             = "$RocmBin;" + $env:PATH
$env:PYTHONPATH       = $DaemonDir
$env:TRITON_CACHE_DIR = $TritonCache

cmd.exe /c "call `"$VsVcVars`" >nul && `"$VenvPython`" -m ptt.kokoro_server 2>&1" > $logFile
