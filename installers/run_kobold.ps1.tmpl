# Auto-generated by install_windows.ps1. Do not edit the installed copy.
# Starts koboldcpp-rocm (our patched llama.cpp fork with ttscpp) in
# Kokoro-TTS-only mode on :13308. koboldcpp_hipblas.dll was built from
# deps/koboldcpp with HIPBLAS for gfx1201 via tools/build_koboldcpp_hip
# .cmd; the DLL needs TheRock's ROCm bin/ registered as a Python DLL
# search path (amdhip64_7 / hipblas / rocblas), which launch_kobold_rocm
# .py handles.
#
# Kokoro runs on the GPU (HIP) via the patched ttscpp in the submodule
# — see the GPU-Kokoro section in README. Set
# $env:VOICE_TTS_KOBOLD_CPU=1 before .\installers\start_services.ps1
# to force the original CPU path back on for A/B comparison.

$VenvPython   = "__VENV_PYTHON__"
$KoboldDir    = "__KOBOLD_DIR__"
$KoboldLauncher = Join-Path $KoboldDir "launch_kobold_rocm.py"
$KokoroModel  = "__KOKORO_GGUF__"
$RocmBin      = "__ROCM_BIN__"

$LogDir = Join-Path $env:LOCALAPPDATA "voice-plugin\logs"
if (-not (Test-Path $LogDir)) { New-Item -ItemType Directory -Path $LogDir -Force | Out-Null }
$ts = (Get-Date).ToString("yyyyMMdd-HHmmss")
$logFile = Join-Path $LogDir "kobold-$ts.log"

$env:PATH         = "$RocmBin;" + $env:PATH
$env:ROCM_SDK_BIN = $RocmBin
# Force MMQ for quantized matmul. TheRock's rocBLAS for gfx1201 ships
# without large parts of its Tensile kernel set; with MMQ off, ggml-cuda
# falls through to rocBLAS for the LLM-style matmuls and hits "Cannot
# find the function: Cijk_..." cascades. MMQ uses ggml's own quantized-
# matmul kernels and avoids rocBLAS entirely for the Q4 path.
$env:GGML_CUDA_FORCE_MMQ = "1"

# --usecuda picks koboldcpp_hipblas.dll, mmq forces the matmul path
# above. --ttsgpu sets inputs.gpulayers=999 which our patched
# kokoro_from_file reads to take the HIP backend path. Set
# VOICE_TTS_KOBOLD_CPU=1 in the launching shell to drop --ttsgpu and
# fall back to ttscpp's CPU Kokoro implementation. --skiplauncher
# skips the GUI, --nomodel keeps the LLM side offline, --port 13308 is
# our convention.
$ExtraArgs = if ($env:VOICE_TTS_KOBOLD_CPU -eq "1") { "" } else { "--ttsgpu" }
cmd.exe /c "`"$VenvPython`" -u `"$KoboldLauncher`" --nomodel --usecuda normal 0 mmq --ttsmodel `"$KokoroModel`" $ExtraArgs --port 13308 --skiplauncher 2>&1" > $logFile
