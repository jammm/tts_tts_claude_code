# Python virtual env — recreated from requirements.txt
.venv/
.venv-*/

# Build outputs & downloaded artifacts — recreated from tools/build_*.cmd
vendor/

# GGUF model weights — fetched from huggingface, not committed
models/

# Submodule build trees (transient)
deps/*/build/
deps/*/build-*/
deps/*/build_*/

# Scratch test scripts and generated WAVs
tmp/

# Python caches
__pycache__/
*.pyc
*.pyo
*.pyd

# Editor / tool caches
.pytest_cache/
.ruff_cache/
.vscode/
.idea/

# Audio test artifacts
*.wav

# openwakeword model cache (we don't use openwakeword anymore, but
# older checkouts may have left this lying around)
pretrained_models/

# Logs
*.log

# Local stress-test / monitor / sweep output
scripts/*.out
scripts/*.csv

# Local-only remote-ops tooling for the Strix Halo NPU test box.
# Contains hardcoded creds and is specific to one private machine; keep
# it out of the repo. Anyone cloning this should follow
# plans/strix-halo-npu-phase1.md to set up their own deployment
# locally, not via this tooling.
scripts/remote_*.py
scripts/README-strix-halo.md

# OS cruft
Thumbs.db
.DS_Store
