# Auto-generated by install_windows.ps1. Do not edit the installed copy.
#
# Starts lemond.exe from a lemondate build tree. One process orchestrates
# everything: STT via whisper-server.exe (ROCm GPU) and TTS via
# kokoro-hip-server.exe (HIP GPU Kokoro through ttscpp), both spawned by
# lemond on demand. Replaces the old split run_lemonade.ps1 (ROCm whisper
# only) + run_kobold.ps1 (HIP Kokoro only) from the pre-monorepo-split
# layout.
#
# Placeholders rendered by installers/install_windows.ps1:
#   @@LEMONDATE_PATH@@    lemondate install root (holds bin/, ptt/, venv/, models/)
#   @@VOICE_PLUGIN_DATA@@ voice-plugin pid + log dir (default %LOCALAPPDATA%\voice-plugin)
#
# NOTE: ErrorActionPreference stays at the default ("Continue"). If we set
# it to "Stop", PowerShell treats ANY line written to a native process's
# stderr as a terminating error and kills the pipeline before the server
# finishes initializing.

$LemondatePath     = "@@LEMONDATE_PATH@@"
$VoicePluginData   = "@@VOICE_PLUGIN_DATA@@"

$LemondExe         = Join-Path $LemondatePath "bin\lemond.exe"
$WhisperExe        = Join-Path $LemondatePath "bin\whisper-server.exe"
$KokoroHipExe      = Join-Path $LemondatePath "bin\kokoro-hip-server.exe"
$KokoroHipModel    = Join-Path $LemondatePath "models\Kokoro_no_espeak_Q4.gguf"
$LemondateBin      = Join-Path $LemondatePath "bin"

$LogDir = Join-Path $VoicePluginData "logs"
if (-not (Test-Path $LogDir)) { New-Item -ItemType Directory -Path $LogDir -Force | Out-Null }
$ts = (Get-Date).ToString("yyyyMMdd-HHmmss")
$logFile = Join-Path $LogDir "lemond-$ts.log"

# Prepend lemondate's bin/ so amdhip64 / hipblas / rocblas / ggml-hip /
# ggml / cpp-httplib DLLs resolve for whisper-server and kokoro-hip-server
# when lemond spawns them.
$env:PATH = "$LemondateBin;" + $env:PATH

# Route rocBLAS's F32 matmul path through hipBLASLt - TheRock's rocBLAS
# for gfx1201 / gfx1151 ships with an incomplete Tensile kernel set, but
# hipBLASLt has full coverage. Same fix that gave HIP Kokoro a 7x speedup
# end-to-end on gfx1201 (poem 8.18s -> 1.19s, median 2.33s -> 0.35s).
# whisper-server's matmul-heavy encoder benefits the same way. Respect a
# user override if they already set it.
if (-not $env:ROCBLAS_USE_HIPBLASLT) {
    $env:ROCBLAS_USE_HIPBLASLT = "1"
}

# Force MMQ for quantized matmul in ggml-cuda. TheRock's rocBLAS for
# gfx1201 ships without large parts of its Tensile kernel set; with MMQ
# off, ggml-cuda falls through to rocBLAS for the LLM-style matmuls and
# hits "Cannot find the function: Cijk_..." cascades. MMQ uses ggml's own
# quantized-matmul kernels and avoids rocBLAS entirely for the Q4 path
# that Kokoro uses.
if (-not $env:GGML_CUDA_FORCE_MMQ) {
    $env:GGML_CUDA_FORCE_MMQ = "1"
}

# kokoro-hip-server traps SIGABRT / SIGSEGV / unhandled C++ exceptions
# and writes a record of the last request + exception reason to this
# file before the CRT fast-fails us out. Without this, ttscpp's
# TTS_ABORT path becomes an opaque "CURL error: Couldn't connect to
# server" in lemond with no clue which input blew up.
if (-not $env:KOKORO_HIP_CRASH_LOG) {
    $env:KOKORO_HIP_CRASH_LOG = Join-Path $VoicePluginData "logs\kokoro-hip-crash.log"
}

# Whisper backend selection. Lemonade's whispercpp recipe supports
# cpu / vulkan / npu / rocm. "rocm" is our lemondate build (whisper-
# server.exe built from src/whisper + src/ggml in lemondate). The
# pre-set env var wins so users on Strix Halo can flip to NPU just by
# setting
#   $env:LEMONADE_WHISPER_BACKEND = "npu"
# before .\installers\start_services.ps1. Default is rocm if lemondate's
# whisper-server.exe is present, otherwise cpu.
$whisperBackend = $env:LEMONADE_WHISPER_BACKEND
if (-not $whisperBackend) {
    if (Test-Path $WhisperExe) { $whisperBackend = "rocm" } else { $whisperBackend = "cpu" }
}
Write-Host "[lemond] whisper backend: $whisperBackend"

if ($whisperBackend -eq "rocm") {
    if (-not (Test-Path $WhisperExe)) {
        Write-Warning "[lemond] LEMONADE_WHISPER_BACKEND=rocm but no whisper-server.exe at $WhisperExe; falling back to cpu"
        $whisperBackend = "cpu"
    } else {
        # Lemonade doesn't ship a ROCm whisper binary - lemondate does,
        # and lemond is patched (jam/windows-rocm-whisper) to accept the
        # "rocm" choice for whispercpp and point at LEMONADE_WHISPERCPP_
        # ROCM_BIN. -nfa disables whisper.cpp's flash-attention path,
        # which rocWMMA miscomputes on gfx1201 and produces garbled
        # output.
        $env:LEMONADE_WHISPERCPP          = "rocm"
        $env:LEMONADE_WHISPERCPP_ROCM_BIN = $WhisperExe
        if (-not $env:LEMONADE_WHISPERCPP_ARGS) {
            $env:LEMONADE_WHISPERCPP_ARGS = "-nfa"
        }
    }
}
if ($whisperBackend -eq "npu") {
    # Lemonade auto-downloads the NPU whisper-server.exe + the model's
    # vitisai-compiled .rai cache from amd/whisper-*-onnx-npu on first
    # use. Requires AMD Ryzen AI XDNA driver to be installed and an
    # XDNA1/XDNA2 NPU on the host (Hawk Point, Strix Point, Strix Halo,
    # Krackan). Lemonade's WhisperServer enforces the device check and
    # will print "Backend not supported on this device" if there's no
    # NPU.
    $env:LEMONADE_WHISPERCPP = "npu"
}
if ($whisperBackend -eq "cpu") {
    $env:LEMONADE_WHISPERCPP = "cpu"
}
if ($whisperBackend -eq "vulkan") {
    $env:LEMONADE_WHISPERCPP = "vulkan"
}

# Kokoro TTS backend selection. lemondate adds a "hip" option that
# launches kokoro-hip-server.exe (ttscpp + our HIP patches: 128-byte
# tensor alignment, reciprocal-as-div, set_inputs staging, shared HIP
# stream, fused snake_1d megakernel, CUDA kernels for the kcpp ttscpp
# dirtypatch ops). Falls back to "cpu" which is lemond's built-in
# kokoros backend. The pre-set env var wins; otherwise default is hip
# if kokoro-hip-server.exe is present, else cpu.
$kokoroBackend = $env:LEMONADE_KOKORO_BACKEND
if (-not $kokoroBackend) {
    if (Test-Path $KokoroHipExe) { $kokoroBackend = "hip" } else { $kokoroBackend = "cpu" }
}
Write-Host "[lemond] kokoro backend: $kokoroBackend"

if ($kokoroBackend -eq "hip") {
    if (-not (Test-Path $KokoroHipExe)) {
        Write-Warning "[lemond] LEMONADE_KOKORO_BACKEND=hip but no kokoro-hip-server.exe at $KokoroHipExe; falling back to cpu"
        $kokoroBackend = "cpu"
    } else {
        $env:LEMONADE_KOKORO_BACKEND  = "hip"
        $env:LEMONADE_KOKORO_HIP_BIN  = $KokoroHipExe
        if (Test-Path $KokoroHipModel) {
            $env:LEMONADE_KOKORO_HIP_MODEL = $KokoroHipModel
        } else {
            Write-Warning "[lemond] Kokoro GGUF not found at $KokoroHipModel; kokoro-hip-server may fail to load. Download Kokoro_no_espeak_Q4.gguf into lemondate's models\ dir."
        }
    }
}
if ($kokoroBackend -eq "cpu") {
    $env:LEMONADE_KOKORO_BACKEND = "cpu"
}

# cmd.exe's 2>&1 merges stderr into stdout without PowerShell's error
# stream interpretation getting in the way.
cmd.exe /c "`"$LemondExe`" 2>&1" > $logFile
$exitCode = $LASTEXITCODE

if ($exitCode -ne 0) {
    # Mirror the error-reporting style of the old run_lemonade.ps1.tmpl:
    # log a warning naming the log file so start_services.ps1's pidfile
    # flow can still tell the user where to look. Don't `throw` - this
    # shim runs under Start-Process and a terminating error here would
    # leave the user with no hint at all.
    Write-Warning "[lemond] lemond.exe exited with code $exitCode - see $logFile"
}
