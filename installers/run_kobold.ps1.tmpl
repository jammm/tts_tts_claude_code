# Auto-generated by install_windows.ps1. Do not edit the installed copy.
# Starts koboldcpp-rocm (our patched llama.cpp fork with ttscpp) in
# Kokoro-TTS-only mode on :13308. koboldcpp_hipblas.dll was built from
# deps/koboldcpp with HIPBLAS for gfx1201 via tools/build_koboldcpp_hip
# .cmd; the DLL needs TheRock's ROCm bin/ registered as a Python DLL
# search path (amdhip64_7 / hipblas / rocblas), which launch_kobold_rocm
# .py handles.
#
# Kokoro runs on CPU here (ttscpp Kokoro is hardcoded cpu_only=true in
# the submodule — see the comment in deps/koboldcpp/otherarch/ttscpp/
# src/ttscpp.cpp::kokoro_from_file). The HIP build was tried; runs
# correctly but ends up slower than the ggml CPU backend on gfx1201
# because of TheRock's incomplete rocBLAS Tensile kernel set, and
# Kokoro is small enough (82 M params, thousands of small ops) that
# per-op kernel-launch latency dominates anyway. The HIP DLL is still
# what we load — it just stays out of Kokoro's hot path.

$VenvPython   = "__VENV_PYTHON__"
$KoboldDir    = "__KOBOLD_DIR__"
$KoboldLauncher = Join-Path $KoboldDir "launch_kobold_rocm.py"
$KokoroModel  = "__KOKORO_GGUF__"
$RocmBin      = "__ROCM_BIN__"

$LogDir = Join-Path $env:LOCALAPPDATA "voice-plugin\logs"
if (-not (Test-Path $LogDir)) { New-Item -ItemType Directory -Path $LogDir -Force | Out-Null }
$ts = (Get-Date).ToString("yyyyMMdd-HHmmss")
$logFile = Join-Path $LogDir "kobold-$ts.log"

$env:PATH         = "$RocmBin;" + $env:PATH
$env:ROCM_SDK_BIN = $RocmBin

# --usecuda normal 0 nommq picks the koboldcpp_hipblas.dll we built
# (koboldcpp.py refuses to load it without --usecuda or --usevulkan).
# --skiplauncher skips the GUI, --nomodel keeps the LLM side offline,
# --port 13308 is our convention. No --ttsgpu — Kokoro is CPU-only.
cmd.exe /c "`"$VenvPython`" -u `"$KoboldLauncher`" --nomodel --usecuda normal 0 nommq --ttsmodel `"$KokoroModel`" --port 13308 --skiplauncher 2>&1" > $logFile
