[submodule "deps/whisper.cpp"]
	path = deps/whisper.cpp
	url = https://github.com/ggml-org/whisper.cpp.git
[submodule "deps/llama.cpp"]
	path = deps/llama.cpp
	url = https://github.com/ggml-org/llama.cpp.git
[submodule "deps/lemonade"]
	path = deps/lemonade
	url = https://github.com/jammm/lemonade.git
	# Our fork of lemonade-sdk/lemonade. The default branch tracks
	# upstream, but the main-repo submodule pointer resolves to our
	# jam/windows-rocm-whisper branch which adds a rocm backend for
	# whispercpp (see Build / runtime notes in README.md).
