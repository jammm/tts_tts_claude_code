# Auto-generated by install_windows.ps1. Do not edit the installed copy.
#
# Starts the experimental ROCm PyTorch Kokoro TTS server with torch
# .compile + Triton on gfx1201, from lemondate's installed tree. Sources
# vcvars64 first so Triton-Windows can find the Windows SDK headers it
# needs to build compiled kernels.
#
# This is the legacy Python GPU Kokoro path - A/B fallback only. The
# default TTS path is kokoro-hip-server.exe spawned by lemond (see
# run_lemond.ps1.tmpl).
#
# Placeholders rendered by installers/install_windows.ps1:
#   @@LEMONDATE_PATH@@    lemondate install root (holds venv\, ptt\, bin\)
#   @@VOICE_PLUGIN_DATA@@ voice-plugin pid + log dir

$LemondatePath   = "@@LEMONDATE_PATH@@"
$VoicePluginData = "@@VOICE_PLUGIN_DATA@@"

$VenvPython   = Join-Path $LemondatePath "venv\Scripts\python.exe"
$DaemonDir    = Join-Path $LemondatePath "ptt"
$LemondateBin = Join-Path $LemondatePath "bin"
$VsVcVars     = "C:\Program Files\Microsoft Visual Studio\2022\Community\VC\Auxiliary\Build\vcvars64.bat"

$LogDir = Join-Path $VoicePluginData "logs"
if (-not (Test-Path $LogDir)) { New-Item -ItemType Directory -Path $LogDir -Force | Out-Null }
$ts = (Get-Date).ToString("yyyyMMdd-HHmmss")
$logFile = Join-Path $LogDir "kokoro-$ts.log"

$TritonCache = Join-Path $VoicePluginData "triton-cache"
if (-not (Test-Path $TritonCache)) { New-Item -ItemType Directory -Path $TritonCache -Force | Out-Null }

# Env vars set here propagate to cmd.exe's child python. Avoid setting
# PATH inside cmd AFTER vcvars - %PATH% expands at parse time (before
# vcvars modifies it) so `set PATH=X;%PATH%` would clobber MSVC. Easier
# to prepend lemondate's bin/ here and let vcvars append MSVC inside cmd.
$env:PATH             = "$LemondateBin;" + $env:PATH
$env:PYTHONPATH       = $LemondatePath
$env:TRITON_CACHE_DIR = $TritonCache

cmd.exe /c "call `"$VsVcVars`" >nul && `"$VenvPython`" -m ptt.kokoro_server 2>&1" > $logFile
