# Python virtual env — recreated from requirements.txt
.venv/
.venv-*/

# Build outputs & downloaded artifacts — recreated from tools/build_*.cmd
vendor/

# GGUF model weights — fetched from huggingface, not committed
models/

# Submodule build trees (transient)
deps/*/build/
deps/*/build-*/
deps/*/build_*/

# Scratch test scripts and generated WAVs
tmp/

# Python caches
__pycache__/
*.pyc
*.pyo
*.pyd

# Editor / tool caches
.pytest_cache/
.ruff_cache/
.vscode/
.idea/

# Audio test artifacts
*.wav

# openwakeword model cache (we don't use openwakeword anymore, but
# older checkouts may have left this lying around)
pretrained_models/

# Logs
*.log

# Local stress-test / monitor / sweep output
scripts/*.out
scripts/*.csv

# OS cruft
Thumbs.db
.DS_Store
