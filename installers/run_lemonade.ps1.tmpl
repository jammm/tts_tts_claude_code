# Auto-generated by install_windows.ps1. Do not edit the installed copy.
# Starts the Lemonade C++ server for voice TTS/STT.

# NOTE: ErrorActionPreference stays at the default ("Continue"). If we set it
# to "Stop", PowerShell treats ANY line written to the native process's
# stderr as a terminating error and kills the pipeline before the server
# finishes initializing.

$LemondExe   = "__LEMOND_EXE__"
$RocmBin     = "__ROCM_BIN__"       # TheRock bin dir (for hipblas/rocblas DLLs)
$WhisperDir  = "__WHISPER_DIR__"    # Our staged whisper-server dir
$WhisperExe  = "__WHISPER_EXE__"    # Our ROCm whisper-server.exe (absolute)

$LogDir = Join-Path $env:LOCALAPPDATA "voice-plugin\logs"
if (-not (Test-Path $LogDir)) { New-Item -ItemType Directory -Path $LogDir -Force | Out-Null }
$ts = (Get-Date).ToString("yyyyMMdd-HHmmss")
$logFile = Join-Path $LogDir "lemonade-$ts.log"

# Prepend ROCm runtime and whisper-server dir to PATH so whisper-server.exe
# can resolve amdhip64 / hipblas / rocblas / ggml-hip at load time.
$env:PATH = "$WhisperDir;$RocmBin;" + $env:PATH
# Route rocBLAS through hipBLASLt — TheRock's rocBLAS for gfx1201 /
# gfx1151 ships with an incomplete Tensile kernel set, but hipBLASLt
# has full coverage. Same fix that gave Kokoro a 7x speedup on the
# HIP path; whisper's matmul-heavy encoder benefits the same way.
$env:ROCBLAS_USE_HIPBLASLT = "1"

# Whisper backend selection. Lemonade's whispercpp recipe supports cpu /
# vulkan / npu / rocm — npu is XDNA2 (Strix Halo / Strix Point / Hawk
# Point); rocm is what we built for gfx1201 here. The pre-set env var
# wins so users on Strix Halo can flip to NPU just by setting
#   $env:LEMONADE_WHISPER_BACKEND = "npu"
# before .\installers\start_services.ps1. Default is rocm if our
# locally-built whisper-server.exe exists, otherwise cpu.
$backend = $env:LEMONADE_WHISPER_BACKEND
if (-not $backend) {
    if ($WhisperExe -and (Test-Path $WhisperExe)) { $backend = "rocm" } else { $backend = "cpu" }
}

if ($backend -eq "rocm") {
    if (-not ($WhisperExe -and (Test-Path $WhisperExe))) {
        Write-Warning "[lemonade] LEMONADE_WHISPER_BACKEND=rocm but no ROCm whisper-server.exe at $WhisperExe; falling back to cpu"
        $backend = "cpu"
    } else {
        # Lemonade doesn't ship a ROCm whisper binary — we patched
        # lemond to accept the "rocm" choice for whispercpp at all (see
        # deps/lemonade/src/cpp/server/backends/whisper_server.cpp) and
        # point it at our binary. -nfa disables whisper.cpp's flash-
        # attention path, which rocWMMA miscomputes on gfx1201 and
        # produces garbled output.
        $env:LEMONADE_WHISPERCPP          = "rocm"
        $env:LEMONADE_WHISPERCPP_ROCM_BIN = $WhisperExe
        $env:LEMONADE_WHISPERCPP_ARGS     = "-nfa"
    }
}
if ($backend -eq "npu") {
    # Lemonade auto-downloads the NPU whisper-server.exe + the model's
    # vitisai-compiled .rai cache from amd/whisper-*-onnx-npu on first
    # use. Requires AMD Ryzen AI XDNA driver to be installed and an
    # XDNA1/XDNA2 NPU on the host (Hawk Point, Strix Point, Strix Halo,
    # Krackan). Lemonade's WhisperServer enforces the device check and
    # will print "Backend not supported on this device" if there's no
    # NPU.
    $env:LEMONADE_WHISPERCPP = "npu"
}
if ($backend -eq "cpu") {
    $env:LEMONADE_WHISPERCPP = "cpu"
}
if ($backend -eq "vulkan") {
    $env:LEMONADE_WHISPERCPP = "vulkan"
}
Write-Host "[lemonade] whisper backend: $($env:LEMONADE_WHISPERCPP)"

# cmd.exe's 2>&1 merges stderr into stdout without PowerShell's error stream
# interpretation getting in the way.
cmd.exe /c "`"$LemondExe`" 2>&1" > $logFile
