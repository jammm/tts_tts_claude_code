# Auto-generated by install_windows.ps1. Do not edit the installed copy.
#
# Launches the PTT + wake-word daemon from lemondate's installed tree.
# The daemon sources (ptt_daemon.py, recorder.py, whisper_wake_listener
# .py, window_check.py, config.py) live in @@LEMONDATE_PATH@@\ptt\ and
# use the venv that lemondate provisions next to them.
#
# Placeholders rendered by installers/install_windows.ps1:
#   @@LEMONDATE_PATH@@    lemondate install root (holds venv\, ptt\, bin\)
#   @@VOICE_PLUGIN_DATA@@ voice-plugin pid + log dir
#
# NOTE: ErrorActionPreference stays at the default ("Continue"). If we
# set it to "Stop", PowerShell treats Python's stderr log output as a
# terminating error and kills the daemon immediately.

$LemondatePath   = "@@LEMONDATE_PATH@@"
$VoicePluginData = "@@VOICE_PLUGIN_DATA@@"

$VenvPython  = Join-Path $LemondatePath "venv\Scripts\python.exe"
$DaemonDir   = Join-Path $LemondatePath "ptt"
$DaemonEntry = Join-Path $DaemonDir "ptt_daemon.py"

$LogDir = Join-Path $VoicePluginData "logs"
if (-not (Test-Path $LogDir)) { New-Item -ItemType Directory -Path $LogDir -Force | Out-Null }
$ts = (Get-Date).ToString("yyyyMMdd-HHmmss")
$logFile = Join-Path $LogDir "ptt-$ts.log"

# Make `import ptt.*` resolve to lemondate's ptt tree so the daemon can
# pull in its sibling modules (recorder, whisper_wake_listener, etc.).
$env:PYTHONPATH = $LemondatePath

# cmd.exe's 2>&1 merges stderr into stdout without PowerShell's error
# stream interpretation getting in the way.
cmd.exe /c "`"$VenvPython`" `"$DaemonEntry`" 2>&1" > $logFile
